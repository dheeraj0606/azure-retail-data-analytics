// File: powerbi/fact_measures.json

{
  "measures": [
    {
      "name": "Total Sales",
      "expression": "SUM(FactSales[TotalAmount])"
    },
    {
      "name": "Total Quantity",
      "expression": "SUM(FactSales[Quantity])"
    },
    {
      "name": "Avg Order Value",
      "expression": "DIVIDE(SUM(FactSales[TotalAmount]), COUNT(FactSales[SalesSK]))"
    }
  ]
}
